<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/etTitulo"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="@string/tituloAgregarLibro"/>

    <EditText
        android:id="@+id/etAutor"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="@string/autorAgregarLibro"/>

    <EditText
        android:id="@+id/etGenero"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="@string/generoAgregarLibro"/>

    <EditText
        android:id="@+id/etValoracion"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="@string/valoracionAgregarLibro"
        android:inputType="number"/>

    <CheckBox
        android:id="@+id/cbLeido"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/leido"/>

</LinearLayout>